{
  "name": "meta-service",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/dungeon/meta-service/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/dungeon/meta-service"],
      "options": {
        "command": "node scripts/build.js",
        "cwd": "apps/dungeon/meta-service"
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/dungeon/meta-service/package.json",
        "{workspaceRoot}/dist/apps/dungeon/meta-service/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "meta-service:build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/dungeon/meta-service/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "meta-service:build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/build.js && node dist/main.js",
        "cwd": "apps/dungeon/meta-service"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/apps/dungeon/meta-service"],
      "options": {
        "command": "pnpm vitest run",
        "cwd": "apps/dungeon/meta-service"
      }
    }
  },
  "tags": []
}
