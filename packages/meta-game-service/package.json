{
  "name": "@org/meta-game-service",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "outputs": [
          "{workspaceRoot}/packages/meta-game-service/dist"
        ],
        "options": {
          "command": "node scripts/build.js",
          "cwd": "packages/meta-game-service"
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/packages/meta-game-service/dist/package.json",
          "{workspaceRoot}/packages/meta-game-service/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/packages/meta-game-service/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "nx:run-commands",
        "options": {
          "command": "node scripts/build.js && node dist/main.js",
          "cwd": "packages/meta-game-service"
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "outputs": [
          "{workspaceRoot}/coverage/packages/meta-game-service"
        ],
        "options": {
          "command": "pnpm vitest run",
          "cwd": "packages/meta-game-service"
        }
      }
    }
  },
  "dependencies": {
    "@fastify/autoload": "~6.0.3",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.1.0",
    "@fastify/sensible": "~6.0.2",
    "async-mutex": "^0.5.0",
    "bcrypt": "^5.1.1",
    "fastify": "~5.2.1",
    "fastify-plugin": "~5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.2.4"
  }
}
